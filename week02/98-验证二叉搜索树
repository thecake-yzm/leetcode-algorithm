/**
 * Definition for a binary tree node.
 * struct TreeNode {
 *     int val;
 *     TreeNode *left;
 *     TreeNode *right;
 *     TreeNode() : val(0), left(nullptr), right(nullptr) {}
 *     TreeNode(int x) : val(x), left(nullptr), right(nullptr) {}
 *     TreeNode(int x, TreeNode *left, TreeNode *right) : val(x), left(left), right(right) {}
 * };
 */
class Solution {
public:
    bool isValidBST(TreeNode* root) {
        long long preval=LLONG_MIN;
        stack<TreeNode*>lmx;
        TreeNode*cur=root;
        while(cur!=nullptr||!lmx.empty())
        {
            while(cur!=nullptr)
            {
                lmx.push(cur);
                cur=cur->left;

            }
            cur=lmx.top();
            lmx.pop();
            if(cur->val<=preval)
            return false;
            preval=cur->val;
            cur=cur->right;
        }
        return true;
    }
};
