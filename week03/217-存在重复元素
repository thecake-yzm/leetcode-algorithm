class Solution {
public:
    bool containsDuplicate(vector<int>& nums) {
        unordered_map<int,vector<int>>mp;
        for(int i=0;i<nums.size();i++)
        mp[nums[i]].push_back(i);
        bool test=false;
        for(int i=0;i<nums.size();i++)
        {
            if(mp[nums[i]].size()>1)
            test=true;
        }
        return test;
    }
};
