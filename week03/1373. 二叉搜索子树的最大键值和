/**
 * Definition for a binary tree node.
 * struct TreeNode {
 *     int val;
 *     TreeNode *left;
 *     TreeNode *right;
 *     TreeNode() : val(0), left(nullptr), right(nullptr) {}
 *     TreeNode(int x) : val(x), left(nullptr), right(nullptr) {}
 *     TreeNode(int x, TreeNode *left, TreeNode *right) : val(x), left(left), right(right) {}
 * };
 */
class Solution {
    int MAXSUM=0;
    struct info{
        bool is_bst;
        int max_val;
        int min_val;
        int sum;

    };
    info dfs(TreeNode*root)
    {
        if(root==nullptr)
        {
            return{true,INT_MIN,INT_MAX,0};
        }
        info left=dfs(root->left);
        info right=dfs(root->right);
        bool cur_isbst=left.is_bst&&right.is_bst&&root->val>left.max_val&&root->val<right.min_val;
        if(cur_isbst)
        {
            int sum1=left.sum+right.sum+root->val;
            MAXSUM=max(sum1,MAXSUM);
            return{true,max({root->val,left.max_val,right.max_val}),
            min({root->val,left.min_val,right.min_val}),sum1};
        }
        else{
            return{false,0,0,0};
        }
    }
public:
    int maxSumBST(TreeNode* root) {
        MAXSUM=0;
        dfs(root);
        return MAXSUM;
    }
};
