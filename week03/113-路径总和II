/**
 * Definition for a binary tree node.
 * struct TreeNode {
 *     int val;
 *     TreeNode *left;
 *     TreeNode *right;
 *     TreeNode() : val(0), left(nullptr), right(nullptr) {}
 *     TreeNode(int x) : val(x), left(nullptr), right(nullptr) {}
 *     TreeNode(int x, TreeNode *left, TreeNode *right) : val(x), left(left), right(right) {}
 * };
 */
class Solution {
public:
    void breaktrack(TreeNode*root,vector<int>&cake,vector<vector<int>>&ans,int remain)
    {
        remain-=root->val;
        cake.push_back(root->val);
        if(remain==0)
        {
            if(root->right==nullptr&&root->left==nullptr)
            {
                ans.push_back(cake);
                cake.pop_back();
                return;
            }
            else if(root->left==nullptr)
            {
                breaktrack(root->right,cake,ans,remain);
            }
            else if(root->right==nullptr)
            {
                breaktrack(root->left,cake,ans,remain);
            }
            else{
                breaktrack(root->left,cake,ans,remain);
                breaktrack(root->right,cake,ans,remain);
            }

        }
        else{
            if(root->left==nullptr&&root->right==nullptr)
            {
                cake.pop_back();
                return;
            }

            else{
                if(root->left)
                breaktrack(root->left,cake,ans,remain);
                if(root->right)
                breaktrack(root->right,cake,ans,remain);
            }

        }
        cake.pop_back();
    }

    vector<vector<int>> pathSum(TreeNode* root, int targetSum) {
        vector<int>cake;
        vector<vector<int>>ans;
        if(root==nullptr)
        return ans;
        cake.push_back(root->val);
        targetSum-=root->val;
        if(targetSum==0)
        {
            if(root->right==nullptr&&root->left==nullptr)
            {
                ans.push_back(cake);
                return ans;
            }

            else{
                if(root->left)
                breaktrack(root->left,cake,ans,targetSum);
                if(root->right)
                breaktrack(root->right,cake,ans,targetSum);
            }

        }
        else
        {
            if(root->right==nullptr&&root->left==nullptr)
            {
                return ans;
            }
           
            else{
                if(root->left)
                breaktrack(root->left,cake,ans,targetSum);
                if(root->right)
                breaktrack(root->right,cake,ans,targetSum);
            }
        }
        return ans;
    }
};
